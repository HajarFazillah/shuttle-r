<?xml version="1.0" ?>
<sdf version="1.9">
    <world name="empty_court">
        <physics name="default_physics" type="ignored">
            <max_step_size>0.001</max_step_size>
            <real_time_factor>1</real_time_factor>
        </physics>

        <model name="ground_plane">
            <static>true</static>
            <link name="link">
                <collision name="collision">
                    <geometry>
                        <plane>
                            <normal>0 0 1</normal>
                            <size>16 10</size>
                        </plane>
                    </geometry>
                </collision>
                <visual name="visual">
                    <geometry>
                        <plane>
                            <normal>0 0 1</normal>
                            <size>16 10</size>
                        </plane>
                    </geometry>
                    <material>
                        <ambient>0.0 0.275 0.165 1</ambient>
                        <diffuse>0.0 0.275 0.165 1</diffuse>
                    </material>
                </visual>
            </link>
